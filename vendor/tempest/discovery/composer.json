{
    "name": "tempest\/discovery",
    "description": "Discover PHP classes and files",
    "license": "MIT",
    "minimum-stability": "dev",
    "require": {
        "php": "^8.5",
        "tempest\/reflection": "3.12.3",
        "tempest\/support": "3.12.3",
        "psr\/container": "^2.0",
        "symfony\/cache": "^7.3"
    },
    "require-dev": {
        "tempest\/container": "3.12.3",
        "php-di\/php-di": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "JooosiMailDeps\\Tempest\\Discovery\\": "src"
        }
